{
    "extends": "./.wxt/tsconfig.json",
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "$lib/*": [
                "./src/lib/*"
            ],
            "#i18n": [
                "./.wxt/i18n/index.ts"
            ],
            "#i18n/*": [
                "./.wxt/i18n/index.ts/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "src/**/*.svelte",
        ".wxt/types/**/*.d.ts"
    ]
}