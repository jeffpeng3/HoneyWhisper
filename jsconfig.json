{
    "extends": "./.wxt/tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "$lib/*": [
                "./src/lib/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "src/**/*.svelte",
        "entrypoints/**/*",
        "entrypoints/**/*.svelte",
        ".wxt/types/**/*.d.ts"
    ]
}